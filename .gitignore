# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Environment
.env
.venv/
venv/
*.log

# IDE
.vscode/
.idea/
.DS_Store

# Cline / temporary
_archive/
.cline/
*.tmp

# Dataset - do not upload raw or processed images
data/raw/
data/processed/images/
data/processed/labels/
data/processed/**/images/
data/processed/**/labels/

# Keep lightweight dataset config if needed
!data/processed/
!data/processed/dataset.yaml
!data/processed/.gitkeep

# Model checkpoints and exported models
outputs/checkpoints/
outputs/logs/
outputs/exported/
*.pt
*.pth
*.onnx
*.engine
*.tflite
*.torchscript

# Ultralytics default output
runs/

# Large visual case images from datasets
outputs/reports/yolo/cases/

# Keep lightweight reports, metrics, and curves
!outputs/
!outputs/reports/
!outputs/reports/yolo/
!outputs/reports/yolo/*.md
!outputs/reports/yolo/*.json
!outputs/reports/yolo/*.csv
!outputs/reports/yolo/*.png
